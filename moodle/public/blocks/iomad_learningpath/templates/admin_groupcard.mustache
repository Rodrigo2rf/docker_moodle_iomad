<div class="groupcard card">
    <div class="card-block">
        <div class="row">
            <div class="col-md-10">
                <h4 class="card-title">{{ name }}</h4>
            </div>
            <div class="col-md-2 text-right">
                <a
                    href="#"
                    data-action="show-groupeditform"
                    data-companyid={{ path.companyid }}
                    data-pathid={{ path.id }}
                    data-groupid={{ id }}
                    title="{{# str }}editgroup, block_iomad_learningpath{{/ str }}"
                >
                    <i class="fa fa-cog fa-2x text-muted"></i>
                </a>
                <a
                    href="#"
                    data-action="show-deletegroupconfirm"
                    data-companyid={{ path.companyid }}
                    data-pathid={{ path.id }}
                    data-groupid={{ id }}
                    data-groupname="{{ name }}"
                    title="{{# str }}deletegroup, block_iomad_learningpath{{/ str }}"
                >
                    <i class="fa fa-trash fa-2x text-muted"></i>
                </a>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="nogroupcourses alert alert-warning" data-groupid="{{ id }}" style="display: none">
                    {{# str }}nocoursesingroup, block_iomad_learningpath{{/ str }}
                </div>
            </div>
        </div>
        <ul class="pathcourselist" data-groupid="{{ id }}"> </ul>
    </div>
</div>
