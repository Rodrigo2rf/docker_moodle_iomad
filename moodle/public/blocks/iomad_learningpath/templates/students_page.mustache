{{!
    @template block_iomad_learningpath/manage_page

    Display students assignments

    Howard Miller 2018
}}

<h2>{{ path.name }}</h2>

<div class="row">
    <div class="col-sm-6">
    </div>
    <div class="col-sm-6">
        <div class="form-group">
            <label for="userfilter">{{# str }}filter, block_iomad_learningpath{{/ str }}</label>
            <input id="userfilter" class="form-control" type="text" name="userfilter">
        </div>
        <div class="form-group">
            <select id="profilefieldid" class="form-control" name="profilefieldid">
            <option value=0>{{# str}}user{{/ str }}</option>
            {{# profilefields }}
                <option value={{ id }}>{{ title }}</option>
            {{/ profilefields }}
            </select>
        </div>
    </div>
</div>

<div class="row m-t-1 m-b-1">
    <div class="col-sm-6">
        <div class="card bg-light">
            <div class="card-header">
                {{# str }}selectedstudents, block_iomad_learningpath{{/ str }}<br />
                <small>
                    {{# str }}clicktoremove, block_iomad_learningpath{{/ str }}.
                </small>
            </div>
            <div class="card-body card-block">
                <p class="card-text">
                    <div id="nopathusers" class="alert alert-warning" style="display: none">
                        {{# str }}nopathusers, block_iomad_learningpath{{/ str }}
                    </div>
                    <ul id="pathuserlist">
                    </ul>
                </p>
            </div>
        </div>
    </div>

    <div class="col-sm-6">
        <div class="card bg-light">
            <div class="card-header">
                {{# str }}prospectivestudents, block_iomad_learningpath{{/ str }}<br />
                <small>{{# str }}clicktoadd, block_iomad_learningpath{{/ str }}</small>
            </div>
            <div class="card-body card-block">
                <p class="card-text">
                    <div id="noprospective" class="alert alert-warning" style="display: none">
                        {{# str }}noprospectiveusers, block_iomad_learningpath{{/ str }}
                    </div>
                    <div id="toomanyprospective" class="alert alert-warning" style="display: none">
                        {{# str }}toomanyprospectiveusers, block_iomad_learningpath{{/ str }}
                    </div>
                    <ul id="prospectivelist">
                    </ul>
                <p>
            </div>
        </div>
    </div>

    </div>
</div>

{{{ done }}}
