{{!
    @template block_iomad_learningpath/manage_page

    Display learning path course list

    Howard Miller 2018
}}

<h2>{{ path.name }}</h2>


<div class="row">
    <div class="col-sm-6">
                <a
                    href="#"
                    data-action="show-groupeditform"
                    data-companyid={{ path.companyid }}
                    data-pathid={{ path.id }}
                    data-groupid=0
                >
            <i class="fa fa-plus fa-2x text-muted"></i>
            <span class="h5 text-muted">{{# str }}addgroup, block_iomad_learningpath{{/ str }}</span>
        </a>
    </div>
    <div class="col-sm-6">
        <form class="form-inline">
            <div class="form-group">
                <input id='id' class='hidden' value={{path.id}}>
                <label for="coursefilter">{{# str }}search{{/ str }}&nbsp</label>
                <input id="coursefilter" class="form-control" type="text" name="coursefilter">
                &nbsp<label for="category">{{# str }}category {{/ str }}&nbsp</label>
                <select id="category" class="form-control">
                    {{# categories }}
                        <option value="{{ id }}">{{ name }}</option>
                    {{/ categories }}
                </select>
            </div>
            <div class="form-group">
            <label for="category">{{# str }}licenseprogram, block_iomad_company_admin {{/ str }}&nbsp</label>
                <select id="program" class="form-control">
                    {{# programlicenses }}
                        <option value="{{ id }}" {{ selected }}>{{ name }}</option>
                    {{/ programlicenses }}
                </select>
           </div>
        </form>
    </div>
</div>
<br>
<div class="row m-t-1 m-b-1">
    <div class="col-sm-6">
        <div class="card bg-light">
            <div class="card-header">
                {{# str }}coursesinpath, block_iomad_learningpath{{/ str }}<br />
                <small>
                    {{# str }}clicktoremove, block_iomad_learningpath{{/ str }}
                </small>
            </div>
            <div class="card-body card-block">
                <p class="card-text">
                    {{# groups }}
                        {{> block_iomad_learningpath/admin_groupcard }}
                    {{/ groups }}
                </p>
            </div>
        </div>
    </div>
    <div class="col-sm-6">
        <div class="card bg-light">
            <div class="card-header">
                {{# str }}prospectivecourses, block_iomad_learningpath{{/ str }}<br />
                <small>{{# str }}clicktoadd, block_iomad_learningpath{{/ str }}</small>
            </div>
            <div class="card-body card-block">
                <p class="card-text">
                    <div id="noprospective" class="alert alert-warning" style="display: none">
                        {{# str }}noprospectivecourses, block_iomad_learningpath{{/ str }}
                    </div>
                    <ul id="prospectivelist">
                    </ul>
                </p>
            </div>
        </div>
    </div>

    </div>
</div>
