{{!
    @template block_iomad_mycourses/mandatory-view

    This template renders the mandatory view for the mycourses block.

    Example context (json):
    {}
}}
<div id="mandatory-view-{{uniqid}}" data-region="mandatory-view">
    <div class="tab-content">
        <div class="tab-pane active " id="mycourses_mandatory_view">
            <div id="paged-content-container-{{uniqid}}" data-region="paged-content-container">
                <div id="page-container-1" data-region="page-container" class="paged-content-page-container" aria-live="polite">
                    <div id="paged-content-page" data-page="1">
                        <ul class="list-group" id="{{uniqid}}">
                            <li class="list-group-item course-listitem border-left-0 border-right-0 border-top-0 px-2 rounded-0" data-region="course-content" data-course-id="5">
                                <div class="row" style="width: 100%;">
                                    <div class="col-md-2 d-flex align-items-center mb-sm-3 mb-md-0" style="min-width: 49%; max-width: 49%;">
                                        <b>{{#str}} course {{/str}}</b>
                                    </div>
                                    <div class="col-md-2 d-flex align-items-center mb-sm-3 mb-md-0" style="min-width: 49%; max-width: 49%;">
                                        <b>{{#str}} status {{/str}}</b>
                                        </div>
                                    </div>
                                </div>
                            </li>
                            {{#mandatoryview.courses}}
                                <li class="list-group-item course-listitem border-left-0 border-right-0 border-top-0 px-2 rounded-0" data-region="course-content" data-course-id="5">
                                    <div class="row" style="width: 100%;">
                                        <div class="col-md-2 d-flex align-items-center mb-sm-3 mb-md-0" style="min-width: 49%; max-width: 49%;">
                                        {{^visible}}
                                            <div class="dimmed_text">
                                        {{/visible}}
                                            {{#visible}}
                                                <a href="{{courseurl}}" tabindex="-1">
                                            {{/visible}}
                                                <div class="w-100 text-truncate">
                                                    {{coursefullname}}
                                                </div>
                                            {{#visible}}
                                                </a>
                                            {{/visible}}
                                            {{^visible}}
                                                </div>
                                            {{/visible}}
                                        </div>
                                        <div class="col-md-9 d-flex flex-column" style="min-width: 49%; max-width: 49%;">
                                            <div class="completion_overview_icon"
                                                 title=
"{{#str}} timeenrolled, local_report_completion {{/str}} {{timeenrolled}}
{{#str}} timestarted, local_report_completion {{/str}} {{timestarted}}
{{#str}} timecompleted, local_report_completion {{/str}} {{timecompleted}}
{{#timeexpires}}
{{#str}} timeexpires, local_report_completion {{/str}} {{timeexpires}}
{{/timeexpires}}
{{#timeprevious}}
{{#str}} previousstatus, block_mycourses, {{timeprevious}} {{/str}}
{{/timeprevious}}
"
                                            >
                                                <span class="dot {{status}}"></span>
                                                &nbsp; {{statusstring}}
                                            </div>
                                        </div>
                                    </div>
                                </li>
                            {{/mandatoryview.courses}}
                            {{^mandatoryview.courses}}
                                </br>
                                <li class="list-group-item course-listitem border-left-0 border-right-0 border-top-0 px-2 rounded-0" data-region="course-content" data-course-id="5">
                                    <div class="text-xs-center text-center m-t-3">
                                        <img class="empty-placeholder-image-lg"
                                            src="{{nocourses}}"
                                            alt="{{#str}} nomandatory, block_iomad_mycourses {{/str}}"
                                            role="presentation">
                                        <p class="text-muted m-t-1">{{#str}} nomandatory, block_iomad_mycourses {{/str}}</p>
                                    </div>
                                </li>
                            {{/mandatoryview.courses}}
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{{#js}}
require(['jquery', 'core/custom_interaction_events'], function($, customEvents) {
    var root = $('#mandatory-view-{{uniqid}}');
    customEvents.define(root, [customEvents.events.activate]);
    root.on(customEvents.events.activate, '[data-toggle="btns"] > .btn', function() {
        root.find('.btn.active').removeClass('active');
    });
});
{{/js}}
